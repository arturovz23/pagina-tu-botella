---
const b = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;

const catalogos = [
  {
    id: 'alimentos',
    tag: 'Hojalata · Aluminio · Twist Off',
    titulo: 'Alimentos y Bebidas',
    desc: 'Catálogo completo de tapas metálicas para la industria alimentaria: conservas, salsas, miel, bebidas y más. Todos los diámetros, acabados y especificaciones técnicas.',
    icono: 'fa-solid fa-utensils',
    color: 'verde',
    url: 'https://www.tecnocapclosures.com/wp-content/uploads/alimentos-y-bebidas-2024.pdf',
  },
  {
    id: 'health',
    tag: 'Aluminio · Premium · Personal Care',
    titulo: 'Health & Beauty',
    desc: 'Soluciones de cierre para cosméticos, suplementos, farmacéuticos y cuidado personal. Acabados premium con opciones de personalización y certificaciones internacionales.',
    icono: 'fa-solid fa-heart-pulse',
    color: 'dorado',
    url: 'https://www.tecnocapclosures.com/wp-content/uploads/healthbeauty_spagna-2024.pdf',
  },
];
---

<section class="section catalogos" id="productos">
  <div class="container">
    <p class="section__tag text-center">Catálogo de productos</p>
    <h2 class="section__title text-center">Explora nuestras líneas</h2>
    <p class="section__subtitle text-center">
      Descarga o consulta nuestros catálogos completos con especificaciones técnicas,
      diámetros, acabados y compatibilidades para cada industria.
    </p>

    <div class="catalogos__grid">
      {catalogos.map(c => (
        <div class={`catalogo-card catalogo-card--${c.color}`}>
          <div class="catalogo-card__icon">
            <i class={c.icono}></i>
          </div>
          <div class="catalogo-card__body">
            <span class="catalogo-card__tag">{c.tag}</span>
            <h3 class="catalogo-card__titulo">{c.titulo}</h3>
            <p class="catalogo-card__desc">{c.desc}</p>
          </div>
          <div class="catalogo-card__actions">
            <a href={c.url} target="_blank" rel="noopener noreferrer" class="btn btn--primary catalogo-card__btn">
              <i class="fa-solid fa-eye"></i> Ver catálogo
            </a>
            <a href={c.url} download target="_blank" rel="noopener noreferrer" class="btn btn--ghost catalogo-card__btn--dl">
              <i class="fa-solid fa-download"></i> Descargar PDF
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="catalogos__cta">
      <p>¿Buscas algo específico o necesitas un producto a la medida?</p>
      <a href={`${b}#contacto`} class="btn btn--ghost btn--ghost-dark">
        <i class="fa-solid fa-comments"></i> Habla con un asesor
      </a>
    </div>
  </div>
</section>
