---
const b = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;
---
<section class="hero" id="inicio">
  <div class="hero__bg">
    <img src={`${b}/img/tapa-hero-seccion.jpg`} alt="Tapas metálicas para alimentos" class="hero__img" />
    <div class="hero__overlay"></div>
  </div>
  <div class="container hero__content">
    <p class="hero__tag"><i class="fa-solid fa-circle-check"></i> Stock en México &nbsp;·&nbsp; Entrega Rápida &nbsp;·&nbsp; +12 años</p>
    <h1 class="hero__title">
      Tapas metálicas<br />
      <span class="hero__title--accent">twist off y rosca</span><br />
      para tus alimentos
    </h1>
    <p class="hero__subtitle">
      Venta y distribución de tapas metálicas para frascos de vidrio.
      Stock permanente en México, precios competitivos y asesoría
      especializada para tu negocio.
    </p>
    <div class="hero__cta">
      <a href="#contacto" class="btn btn--primary">
        <i class="fa-solid fa-tag"></i> Solicitar cotización
      </a>
      <a href="https://wa.me/525610201865?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20tapas%20met%C3%A1licas." target="_blank" class="btn btn--whatsapp">
        <i class="fa-brands fa-whatsapp"></i> WhatsApp ahora
      </a>
    </div>
  </div>
</section>
